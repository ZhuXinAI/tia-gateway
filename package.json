{
  "name": "tia-gateway",
  "version": "0.4.4",
  "description": "Channel-to-agent gateway with pluggable agent protocols and first-class ACP support.",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "tia-gateway": "./dist/bin/tia-gateway.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "pnpm run clean && pnpm run build:web && tsc -p tsconfig.json && node ./scripts/copy-web-assets.mjs",
    "build:web": "pnpm --filter @tia-gateway/web-shell run build",
    "prepack": "pnpm run build",
    "test": "pnpm run build:web && tsx --test test/**/*.test.ts",
    "check": "pnpm run build && pnpm run test",
    "start": "node dist/bin/tia-gateway.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@mcpc-tech/acp-ai-provider": "^0.3.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ai": "6.0.145",
    "commander": "^14.0.3",
    "qrcode-terminal": "^0.12.0",
    "resumable-stream": "^2.2.12",
    "telegraf": "^4.16.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhuXinAI/tia-gateway.git"
  },
  "homepage": "https://github.com/ZhuXinAI/tia-gateway#readme",
  "bugs": {
    "url": "https://github.com/ZhuXinAI/tia-gateway/issues"
  },
  "license": "MIT",
  "keywords": [
    "gateway",
    "wechat",
    "lark",
    "whatsapp",
    "telegram",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "bridge"
  ],
  "publishConfig": {
    "access": "public"
  }
}
