{
  "name": "tia-gateway",
  "version": "0.1.0",
  "description": "Channel-to-agent gateway with pluggable agent protocols and first-class ACP support.",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "tia-gateway": "./dist/bin/tia-gateway.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "tsx --test test/**/*.test.ts",
    "check": "npm run build && npm test",
    "start": "node dist/bin/tia-gateway.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "gateway",
    "wechat",
    "lark",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "bridge"
  ],
  "publishConfig": {
    "access": "public"
  }
}
